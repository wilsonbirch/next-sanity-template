# --- Sanity ---
# From sanity.io/manage after creating a project (see README setup section).
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Optional: shown as the Studio title in the /studio UI.
NEXT_PUBLIC_SANITY_STUDIO_TITLE=CMS

# Read token (only required if fetching draft/preview content from Server
# Components). Leave blank if you only read published content.
SANITY_API_READ_TOKEN=

# Write token, used by scripts/seed-sanity.mjs. Create a token with
# "Editor" rights in sanity.io/manage → API → Tokens.
SANITY_API_WRITE_TOKEN=

# --- Site ---
# Used for absolute URLs (sitemap, OG images, metadataBase).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Email (contact form) ---
# Get an API key from resend.com/api-keys. Without these the /api/contact
# endpoint still returns 200 but logs submissions to the server console
# instead of sending email.
RESEND_API_KEY=
CONTACT_FORM_TO_EMAIL=
# Optional: override the From address. Default is Resend's onboarding sender.
CONTACT_FORM_FROM_EMAIL=
